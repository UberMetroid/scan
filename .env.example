# Server Configuration
PORT=4503
BASE_URL=http://localhost:4503

# Application Settings
SITE_TITLE=Scan

# Security: PIN Protection (4-64 characters, leave empty to disable)
SCAN_PIN=

# CORS Configuration
ALLOWED_ORIGINS=*

# Timezone Configuration
TZ=UTC

# Application Specific Settings
PAGE_HISTORY_COOKIE_AGE=365
MAX_ATTEMPTS=5
# Show the language picker in the header. Accepts true/false/1/0/yes/no/on/off;
# unset is treated as `true` because Scan is multilingual by design.
ENABLE_TRANSLATION=true
# Show the theme selector in the header.
ENABLE_THEMES=true
# Show the print button in the header.
ENABLE_PRINT=true

# Filesystem Paths
#
# SCAN_DATA_DIR: Directory where Scan persists runtime state. The
#   high-score leaderboard is written to `${SCAN_DATA_DIR}/leaderboard.json`
#   on every successful submission (atomic temp-file + rename). Back this
#   directory up; deleting it wipes the leaderboard.
#   Default: `./data/` (relative to the working directory).
#
# SCAN_FRONTEND_DIR: Path to the prebuilt Trunk SPA bundle (the directory
#   that contains `index.html`, `service-worker.js`, and `Assets/`).
#   Override this if you've symlinked the bundle elsewhere or want to
#   point Scan at a custom build.
#   Default: `./frontend/dist/`.
SCAN_DATA_DIR=data
SCAN_FRONTEND_DIR=frontend/dist
